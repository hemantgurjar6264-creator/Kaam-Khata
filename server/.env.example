# Port the Express server will listen on
PORT=5000

# Environment: development | production
NODE_ENV=development

# MongoDB Atlas connection string
# Get this from Atlas -> Database -> Connect -> Drivers (see README for steps)
MONGODB_URI=mongodb+srv://hg4936253_db_user:hemant123@cluster0.ree8mso.mongodb.net/kaamkhata?retryWrites=true&w=majority&appName=Cluster0
# Secret key used to sign JWT tokens - use a long random string in production
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET= you key
# JWT cookie expiry, in days
JWT_EXPIRES_DAYS=7

# URL of the frontend (Vite dev server), used for CORS
CLIENT_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Firebase Admin — used ONLY to verify the phone-OTP the user confirms on the
# client during "Forgot Password". We never send OTPs from the server.
#
# How to get these values:
# 1. Firebase Console -> your project -> ⚙️ Project settings -> Service accounts
# 2. Click "Generate new private key" — this downloads a JSON file.
# 3. Copy the matching fields from that JSON into the three variables below.
#    (project_id -> FIREBASE_PROJECT_ID, client_email -> FIREBASE_CLIENT_EMAIL,
#    private_key -> FIREBASE_PRIVATE_KEY)
# 4. Keep the \n sequences in the private key literally — do not replace them
#    with real line breaks in this file, the app converts them at runtime.
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=abc
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
